{
  "name": "@zodiacs/sdk",
  "version": "0.2.0",
  "description": "Official read-only TypeScript SDK for the canonical Zodiacs.org registry, native Solana Zodiacs assets, and official bridged Base representations.",
  "license": "MIT",
  "keywords": [
    "zodiacs",
    "zodiacs-org",
    "sdk",
    "solana",
    "spl",
    "base",
    "bridged-assets",
    "wormhole",
    "canonical-registry",
    "cultural-assets",
    "identity",
    "react",
    "typescript",
    "read-only"
  ],
  "homepage": "https://zodiacs.org/sdk",
  "bugs": {
    "url": "https://github.com/ZodiacsOfficial/sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZodiacsOfficial/sdk.git"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./registry/zodiacs.registry.json": {
      "default": "./registry/zodiacs.registry.json"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "registry"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --tsconfig tsconfig.build.json --external react --external react/jsx-runtime --external @solana/web3.js --external viem",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run src/**/*.test.ts src/**/*.test.tsx"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.0",
    "viem": "^2.23.0"
  },
  "peerDependencies": {
    "react": ">=18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
